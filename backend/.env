# 后端环境变量配置
# Django 配置
DJANGO_SECRET_KEY=your-very-secret-key-change-in-production
DJANGO_DEBUG=True

# 数据库配置 - SQLite 模式下只有 DB_ENGINE 和 DB_NAME 有效
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
# 以下参数在 SQLite 模式下无效，仅保留用于 MySQL 模式
# DB_USER=
# DB_PASSWORD=
# DB_HOST=
# DB_PORT=

# 其他配置
ALLOWED_HOSTS=*