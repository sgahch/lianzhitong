# 生产环境后端配置
# Django 配置
DJANGO_SECRET_KEY=your-production-secret-key-change-after-deployment
DJANGO_DEBUG=False

# 数据库配置 - SQLite 模式
DB_ENGINE=django.db.backends.sqlite3
# 生产环境中使用绝对路径
DB_NAME=/var/www/lianzhitong/db.sqlite3

# 以下参数在 SQLite 模式下无效，仅保留用于 MySQL 模式
# DB_USER=
# DB_PASSWORD=
# DB_HOST=
# DB_PORT=

# 其他配置
ALLOWED_HOSTS=8.148.31.90,127.0.0.1,localhost